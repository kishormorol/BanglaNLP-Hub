---
/** Home — ported from design-reference/Home.dc.html, with a layered visual
 * polish (aurora hero, glass stat cards, scroll-reveal). All counts and content
 * are still derived from /data at build time — the polish is presentation only. */
import Base from '../layouts/Base.astro';
import Search from '../components/Search.astro';
import { tasks, byTask, stats, recentlyAdded, typeTone, models, datasets, tools } from '../lib/data.ts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

/** Every catalog entry with a link, for deriving contributor counts. */
const allEntries = [...models, ...datasets, ...tools];

// Counts are derived from /data at build time — never written down.
const statCards = [
  { label: 'Papers', value: stats.papers, href: `${base}/papers` },
  { label: 'Datasets', value: stats.datasets, href: `${base}/datasets` },
  { label: 'Models', value: stats.models, href: `${base}/tasks` },
  { label: 'Tools', value: stats.tools, href: `${base}/tools` },
];

const taskCards = tasks.map((t) => ({
  ...t,
  href: `${base}/tasks/${t.id}`,
  counts: `${byTask.datasets(t.id).length} datasets · ${byTask.papers(t.id).length} papers`,
}));

const recent = recentlyAdded(6);

/**
 * Groups, labs, and maintainers whose openly released work the catalog is built
 * on. This is NOT an editorial "who is best" ranking — every entry credits a
 * real, verifiable contribution that appears in the catalog, and each link is
 * the parent of URLs already in the link-checked data. `entries` is derived from
 * /data at build time (like every other count on this page), never written down.
 * To add someone, credit a concrete contribution — do not invent a claim.
 */
const contributors = [
  {
    name: 'BUET CSE NLP',
    handle: 'csebuetnlp',
    match: 'csebuetnlp',
    blurb: 'The research group behind much of the modern Bangla NLP stack.',
    notable: 'BanglaBERT · BanglaT5 · XL-Sum · BanglaNMT',
    link: 'https://huggingface.co/csebuetnlp',
  },
  {
    name: 'Bengali.AI',
    handle: 'bengaliai',
    match: 'bengaliai',
    blurb: 'Community non-profit running open speech and handwriting datasets and competitions.',
    notable: 'OOD-Speech and community ASR / OCR corpora',
    link: 'https://bengaliai.github.io',
  },
  {
    name: 'Hishab',
    handle: 'hishab',
    match: 'hishab',
    blurb: 'Builds and openly releases Bangla large language models.',
    notable: 'TituLM Bangla LLM family',
    link: 'https://huggingface.co/hishab',
  },
  {
    name: 'Language Technology Lab',
    handle: 'LanguageTechnologyLab',
    match: 'LanguageTechnologyLab',
    blurb: 'Releases code-mixed and offensive-language datasets for Bangla.',
    notable: 'TB-OLID · SentMix-3L · OffMix-3L',
    link: 'https://github.com/LanguageTechnologyLab',
  },
  {
    name: 'Sagor Sarker',
    handle: 'sagorsarker',
    match: 'sagorsarker',
    blurb: 'Maintainer of the BNLP toolkit and early open Bangla models.',
    notable: 'bnlp-toolkit · bangla-bert-base',
    link: 'https://huggingface.co/sagorsarker',
  },
].map((c) => ({
  ...c,
  entries: allEntries.filter((e) => String(e.link ?? '').includes(c.match)).length,
}));
---

<Base title="BanglaNLP Hub — the definitive index of Bangla NLP research" footerShowData>
  <main class="home">
    <div class="aurora" aria-hidden="true">
      <span class="blob b1"></span>
      <span class="blob b2"></span>
      <span class="blob b3"></span>
      <span class="grid"></span>
    </div>

    <section class="hero">
      <div class="eyebrow bn">
        <span class="spark" aria-hidden="true"></span>
        বাংলা এনএলপি গবেষণার নির্ভরযোগ্য সূচি
      </div>
      <h1>
        The definitive index of <span class="grad">Bangla NLP</span> research
      </h1>
      <p class="lede">
        Papers, datasets, models, tools, and benchmarks for Bengali natural language processing —
        community-maintained, link-verified, and open on GitHub.
      </p>
      <Search variant="hero" id="hero-search" />
    </section>

    <section class="stats reveal">
      {
        statCards.map((s) => (
          <a class="statcard" href={s.href}>
            <span class="sheen" aria-hidden="true" />
            <div class="statnum">{s.value}</div>
            <div class="statlabel">{s.label}</div>
          </a>
        ))
      }
    </section>

    <section class="body">
      <div class="reveal">
        <div class="sechead">
          <h2>
            Browse by task <span class="bn sub">· কাজ অনুযায়ী</span>
          </h2>
          <a href={`${base}/tasks`} class="seelink">All tasks →</a>
        </div>
        <div class="taskgrid">
          {
            taskCards.map((t) => (
              <a class="taskcard" href={t.href}>
                <div class="bn tasktag">{t.bn}</div>
                <div class="taskname">{t.name}</div>
                <div class="taskcount">{t.counts}</div>
              </a>
            ))
          }
        </div>
      </div>

      <div class="reveal">
        <div class="sechead">
          <h2>Recently added</h2>
          <span class="sub"
            >most recently verified · <span class="mono">main</span></span
          >
        </div>
        <div class="feed">
          {
            recent.map((r) => (
              <a class="feedrow" href={r.href}>
                <span
                  class="pill"
                  style={`color:${typeTone[r.type].fg};background:${typeTone[r.type].bg}`}
                >
                  {r.type}
                </span>
                <span class="feedname">{r.name}</span>
                <span class="feedtask">{r.task}</span>
                <span class="feeddate mono">{r.date}</span>
              </a>
            ))
          }
        </div>
      </div>

      <div class="reveal">
        <div class="sechead col">
          <h2>
            Powered by the community <span class="bn sub">· সম্প্রদায়</span>
          </h2>
          <p class="secblurb">
            Bangla is low-resource, and this catalog exists because a handful of groups, labs, and
            maintainers release their work openly. These are some whose datasets, models, and tools
            the Hub is built on — credited by real contribution, not ranking.
          </p>
        </div>
        <div class="contribgrid">
          {
            contributors.map((c) => (
              <a class="contribcard" href={c.link} target="_blank" rel="noopener">
                <div class="contribhead">
                  <span class="contribname">{c.name}</span>
                  {c.entries > 0 && <span class="contribcount mono">{c.entries} in catalog</span>}
                  <span class="contribarrow">↗</span>
                </div>
                <p class="contribblurb">{c.blurb}</p>
                <div class="contribnotable">{c.notable}</div>
              </a>
            ))
          }
        </div>
        <p class="secfoot">
          Missing someone whose open work belongs here?{' '}
          <a href={`${base}/contribute`}>Add them via PR</a> — with a concrete contribution, not a
          claim.
        </p>
      </div>
    </section>
  </main>
</Base>

<style>
  .home {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* --- aurora backdrop (behind hero + stats) --- */
  .aurora {
    position: absolute;
    inset: -40px 0 auto 0;
    height: 720px;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .aurora .blob {
    position: absolute;
    width: 560px;
    height: 560px;
    border-radius: 50%;
    filter: blur(90px);
    opacity: 0.4;
    mix-blend-mode: multiply;
  }
  :global(html.dark) .aurora .blob {
    mix-blend-mode: screen;
    opacity: 0.32;
  }
  .b1 {
    background: radial-gradient(circle, var(--green), transparent 62%);
    top: -180px;
    left: -60px;
    animation: drift1 20s ease-in-out infinite;
  }
  .b2 {
    background: radial-gradient(circle, var(--blue), transparent 62%);
    top: -140px;
    right: -40px;
    animation: drift2 26s ease-in-out infinite;
  }
  .b3 {
    background: radial-gradient(circle, var(--gold), transparent 64%);
    top: 30px;
    left: 42%;
    animation: drift3 30s ease-in-out infinite;
  }
  /* faint dotted grid for the "product" feel, faded at the edges */
  .aurora .grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(var(--border) 1px, transparent 1px);
    background-size: 26px 26px;
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 30%, #000 30%, transparent 72%);
    mask-image: radial-gradient(ellipse 70% 60% at 50% 30%, #000 30%, transparent 72%);
    opacity: 0.55;
  }
  @keyframes drift1 {
    50% {
      transform: translate(60px, 40px) scale(1.12);
    }
  }
  @keyframes drift2 {
    50% {
      transform: translate(-50px, 50px) scale(1.08);
    }
  }
  @keyframes drift3 {
    50% {
      transform: translate(30px, -30px) scale(1.1);
    }
  }

  /* --- hero --- */
  .hero {
    position: relative;
    z-index: 1;
    padding: 76px 0 40px;
    text-align: center;
  }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 600;
    color: var(--red);
    letter-spacing: 0.02em;
    margin-bottom: 14px;
    padding: 5px 14px 5px 11px;
    border: 1px solid var(--border);
    border-radius: 99px;
    background: var(--surface);
    background: color-mix(in srgb, var(--surface) 55%, transparent);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
  }
  .spark {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--green) 60%, transparent);
    animation: pulse 2.6s ease-out infinite;
  }
  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--green) 55%, transparent);
    }
    70% {
      box-shadow: 0 0 0 9px transparent;
    }
    100% {
      box-shadow: 0 0 0 0 transparent;
    }
  }
  .hero h1 {
    font-family: 'Spectral', serif;
    font-weight: 600;
    font-size: clamp(30px, 5vw, 52px);
    line-height: 1.12;
    margin: 0 auto;
    max-width: 760px;
    text-wrap: balance;
  }
  .grad {
    background: linear-gradient(115deg, var(--green) 10%, var(--blue) 60%, var(--gold) 110%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .lede {
    color: var(--text2);
    font-size: 16.5px;
    max-width: 560px;
    margin: 18px auto 0;
    line-height: 1.6;
    text-wrap: pretty;
  }

  /* --- glass stat cards --- */
  .stats {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 14px;
    padding: 8px 0 52px;
    max-width: 820px;
    margin: 0 auto;
  }
  .statcard {
    position: relative;
    overflow: hidden;
    text-decoration: none;
    background: var(--surface);
    background: color-mix(in srgb, var(--surface) 68%, transparent);
    -webkit-backdrop-filter: blur(12px) saturate(1.25);
    backdrop-filter: blur(12px) saturate(1.25);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 20px 16px;
    text-align: center;
    transition:
      transform 0.28s cubic-bezier(0.2, 0.7, 0.2, 1),
      box-shadow 0.28s ease,
      border-color 0.28s ease;
  }
  .statcard:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--green) 55%, var(--border));
    box-shadow: 0 16px 34px -16px color-mix(in srgb, var(--green) 55%, transparent);
  }
  .statcard .sheen {
    position: absolute;
    inset: 0 0 auto 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--green), var(--blue), transparent);
    opacity: 0.6;
  }
  .statnum {
    font-family: 'Spectral', serif;
    font-weight: 700;
    font-size: 36px;
    line-height: 1;
    background: linear-gradient(125deg, var(--green), var(--blue));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .statlabel {
    font-size: 12.5px;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text2);
    margin-top: 9px;
  }

  /* --- body sections --- */
  .body {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 44px;
    padding-bottom: 68px;
  }
  .sechead {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 16px;
  }
  .sechead.col {
    display: block;
  }
  .sechead h2 {
    font-family: 'Spectral', serif;
    font-weight: 600;
    font-size: 24px;
    margin: 0;
  }
  .sub {
    font-size: 13px;
    color: var(--text2);
    font-weight: 500;
  }
  .sechead h2 .sub {
    font-size: 15px;
  }
  .mono {
    font-family: 'IBM Plex Mono', monospace;
  }
  .seelink {
    font-size: 13.5px;
    font-weight: 500;
    white-space: nowrap;
  }
  .secblurb {
    color: var(--text2);
    font-size: 14px;
    line-height: 1.6;
    margin: 8px 0 0;
    max-width: 640px;
    text-wrap: pretty;
  }

  /* task cards */
  .taskgrid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
    gap: 12px;
  }
  .taskcard {
    position: relative;
    text-decoration: none;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    overflow: hidden;
    transition:
      transform 0.24s cubic-bezier(0.2, 0.7, 0.2, 1),
      box-shadow 0.24s ease,
      border-color 0.24s ease;
  }
  .taskcard::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(var(--green), var(--blue));
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.24s ease;
  }
  .taskcard:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--green) 45%, var(--border));
    box-shadow: 0 12px 26px -14px color-mix(in srgb, var(--green) 50%, transparent);
  }
  .taskcard:hover::before {
    transform: scaleY(1);
  }
  .tasktag {
    font-size: 12px;
    color: var(--red);
    font-weight: 600;
  }
  .taskname {
    font-weight: 600;
    font-size: 15.5px;
    color: var(--text);
  }
  .taskcount {
    font-size: 12.5px;
    color: var(--text2);
    margin-top: auto;
  }

  /* recently-added feed */
  .feed {
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--surface);
    background: color-mix(in srgb, var(--surface) 82%, transparent);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    overflow: hidden;
  }
  .feedrow {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: background 0.18s ease;
  }
  .feedrow:last-child {
    border-bottom: none;
  }
  .feedrow:hover {
    background: var(--surface2);
  }
  .pill {
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 99px;
    flex-shrink: 0;
    width: 64px;
    text-align: center;
  }
  .feedname {
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .feedtask {
    margin-left: auto;
    font-size: 12px;
    color: var(--text2);
    flex-shrink: 0;
  }
  .feeddate {
    font-size: 11.5px;
    color: var(--text2);
    flex-shrink: 0;
  }

  /* contributors */
  .contribgrid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 12px;
  }
  .contribcard {
    text-decoration: none;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    transition:
      transform 0.24s cubic-bezier(0.2, 0.7, 0.2, 1),
      box-shadow 0.24s ease,
      border-color 0.24s ease;
  }
  .contribcard:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--green) 45%, var(--border));
    box-shadow: 0 12px 26px -14px color-mix(in srgb, var(--green) 45%, transparent);
  }
  .contribhead {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .contribname {
    font-weight: 600;
    font-size: 15.5px;
    color: var(--text);
  }
  .contribcount {
    font-size: 11px;
    color: var(--text2);
  }
  .contribarrow {
    margin-left: auto;
    font-size: 12px;
    color: var(--text2);
  }
  .contribblurb {
    margin: 0;
    font-size: 12.5px;
    color: var(--text2);
    line-height: 1.55;
    text-wrap: pretty;
  }
  .contribnotable {
    font-size: 12px;
    color: var(--green);
    margin-top: auto;
    line-height: 1.5;
    text-wrap: pretty;
  }
  .secfoot {
    color: var(--text2);
    font-size: 12.5px;
    line-height: 1.6;
    margin: 12px 0 0;
  }

  /* scroll reveal — the hidden start state is gated behind `html.js`, so with
     scripting off the content is simply visible (never stranded at opacity 0). */
  .reveal {
    transition:
      opacity 0.6s ease,
      transform 0.6s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  :global(html.js) .reveal {
    opacity: 0;
    transform: translateY(16px);
  }
  :global(html.js) .reveal.in {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .aurora .blob,
    .spark {
      animation: none;
    }
    :global(html.js) .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .statcard,
    .taskcard,
    .contribcard {
      transition: border-color 0.2s ease;
    }
  }
</style>

<script>
  // Progressive enhancement: reveal sections as they scroll in. If IO is
  // unavailable or JS is off, the .reveal CSS still lands at its final state
  // via the fallback below, so nothing is ever hidden without a way back.
  const els = document.querySelectorAll<HTMLElement>('.reveal');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduce || !('IntersectionObserver' in window)) {
    els.forEach((el) => el.classList.add('in'));
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add('in');
            io.unobserve(e.target);
          }
        }
      },
      { rootMargin: '0px 0px -8% 0px', threshold: 0.08 },
    );
    els.forEach((el) => io.observe(el));
    // Safety net: if something never intersects, reveal it after a beat.
    setTimeout(() => els.forEach((el) => el.classList.add('in')), 1200);
  }
</script>
