---
/** Home — ported from design-reference/Home.dc.html */
import Base from '../layouts/Base.astro';
import Search from '../components/Search.astro';
import { tasks, byTask, stats, recentlyAdded, typeTone } from '../lib/data.ts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Counts are derived from /data at build time — never written down.
const statCards = [
  { label: 'Papers', value: stats.papers, href: `${base}/papers` },
  { label: 'Datasets', value: stats.datasets, href: `${base}/datasets` },
  { label: 'Models', value: stats.models, href: `${base}/tasks` },
  { label: 'Tools', value: stats.tools, href: `${base}/tools` },
];

const taskCards = tasks.map((t) => ({
  ...t,
  href: `${base}/tasks/${t.id}`,
  counts: `${byTask.datasets(t.id).length} datasets · ${byTask.papers(t.id).length} papers`,
}));

const recent = recentlyAdded(6);
---

<Base title="BanglaNLP Hub — the definitive index of Bangla NLP research" footerShowData>
  <main style="max-width:1200px;margin:0 auto;padding:0 20px">
    <section style="padding:72px 0 40px;text-align:center">
      <div
        class="bn"
        style="font-size:15px;font-weight:600;color:var(--red);letter-spacing:0.02em;margin-bottom:14px"
      >
        বাংলা এনএলপি গবেষণার নির্ভরযোগ্য সূচি
      </div>
      <h1
        style="font-family:'Spectral',serif;font-weight:600;font-size:clamp(30px,5vw,50px);line-height:1.12;margin:0 auto;max-width:760px;text-wrap:balance"
      >
        The definitive index of Bangla NLP research
      </h1>
      <p
        style="color:var(--text2);font-size:16.5px;max-width:560px;margin:18px auto 0;line-height:1.6;text-wrap:pretty"
      >
        Papers, datasets, models, tools, and benchmarks for Bengali natural language processing —
        community-maintained, link-verified, and open on GitHub.
      </p>
      <Search variant="hero" id="hero-search" />
    </section>

    <section
      style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;padding:8px 0 48px;max-width:820px;margin:0 auto"
    >
      {
        statCards.map((s) => (
          <a
            class="card"
            href={s.href}
            style="text-decoration:none;background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:18px 16px;text-align:center"
          >
            <div style="font-family:'Spectral',serif;font-weight:700;font-size:34px;color:var(--green);line-height:1">
              {s.value}
            </div>
            <div style="font-size:12.5px;font-weight:500;letter-spacing:0.05em;text-transform:uppercase;color:var(--text2);margin-top:8px">
              {s.label}
            </div>
          </a>
        ))
      }
    </section>

    <section style="display:grid;grid-template-columns:1fr;gap:40px;padding-bottom:64px">
      <div>
        <div
          style="display:flex;align-items:baseline;justify-content:space-between;gap:16px;margin-bottom:16px"
        >
          <h2 style="font-family:'Spectral',serif;font-weight:600;font-size:24px;margin:0">
            Browse by task <span class="bn" style="font-size:15px;color:var(--text2);font-weight:500"
              >· কাজ অনুযায়ী</span
            >
          </h2>
          <a href={`${base}/tasks`} style="font-size:13.5px;font-weight:500">All tasks →</a>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:12px">
          {
            taskCards.map((t) => (
              <a
                class="card taskcard"
                href={t.href}
                style="text-decoration:none;background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:16px;display:flex;flex-direction:column;gap:6px"
              >
                <div class="bn" style="font-size:12px;color:var(--red);font-weight:600">{t.bn}</div>
                <div style="font-weight:600;font-size:15.5px;color:var(--text)">{t.name}</div>
                <div style="font-size:12.5px;color:var(--text2);margin-top:auto">{t.counts}</div>
              </a>
            ))
          }
        </div>
      </div>

      <div>
        <div
          style="display:flex;align-items:baseline;justify-content:space-between;gap:16px;margin-bottom:16px"
        >
          <h2 style="font-family:'Spectral',serif;font-weight:600;font-size:24px;margin:0">
            Recently added
          </h2>
          <span style="font-size:12.5px;color:var(--text2)"
            >most recently verified · <span style="font-family:'IBM Plex Mono',monospace">main</span
            ></span
          >
        </div>
        <div
          style="border:1px solid var(--border);border-radius:12px;background:var(--surface);overflow:hidden"
        >
          {
            recent.map((r) => (
              <a
                class="feedrow"
                href={r.href}
                style="display:flex;align-items:center;gap:14px;padding:12px 16px;border-bottom:1px solid var(--border);text-decoration:none"
              >
                <span
                  style={`font-size:10.5px;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;color:${typeTone[r.type].fg};background:${typeTone[r.type].bg};padding:3px 8px;border-radius:99px;flex-shrink:0;width:64px;text-align:center`}
                >
                  {r.type}
                </span>
                <span style="font-size:14px;font-weight:500;color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                  {r.name}
                </span>
                <span style="margin-left:auto;font-size:12px;color:var(--text2);flex-shrink:0">
                  {r.task}
                </span>
                <span style="font-family:'IBM Plex Mono',monospace;font-size:11.5px;color:var(--text2);flex-shrink:0">
                  {r.date}
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Base>

<style>
  .card:hover {
    border-color: var(--green) !important;
  }
  .taskcard:hover {
    box-shadow: 0 4px 14px rgba(14, 60, 40, 0.07);
  }
  .feedrow:hover {
    background: var(--surface2);
  }
</style>
