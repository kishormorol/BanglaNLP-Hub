---
// Footer — transcribed from the prototype. Home's variant carries an extra
// "data on GitHub" link; `showData` reproduces that difference.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
interface Props {
  showData?: boolean;
}
const { showData = false } = Astro.props;
---

<footer style="border-top:1px solid var(--border);padding:28px 20px">
  <div
    style="max-width:1200px;margin:0 auto;display:flex;flex-wrap:wrap;gap:16px;align-items:baseline;justify-content:space-between"
  >
    <div style="font-size:13px;color:var(--text2)">
      <span class="bn" style="color:var(--green);font-weight:600">বাংলা</span> NLP Hub · maintained
      by{' '}
      <a href={`${base}/about`}>ELITE Research Lab</a>
      {
        showData && (
          <>
            {' · data on '}
            <a href="https://github.com/kishormorol/BanglaNLP-Hub" target="_blank" rel="noopener">
              GitHub
            </a>
          </>
        )
      }
    </div>
    <div style="display:flex;gap:16px;font-size:13px">
      <a href={`${base}/contribute`}>Contribute</a>
      <a href={`${base}/about`}>Cite this catalog</a>
    </div>
  </div>
</footer>
